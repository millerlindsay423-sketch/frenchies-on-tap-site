# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Long-lived Instagram access token from the Meta developer console
# (App dashboard > Instagram API > API setup with Instagram login > Generate access tokens)
IG_ACCESS_TOKEN=

# Palmer's numeric Instagram Business Account ID (filled in after running whoami.js once)
IG_BUSINESS_ACCOUNT_ID=

# Instagram app secret (App dashboard > App settings > Basic > Instagram app secret)
# Needed later for refreshing the long-lived token before it expires
IG_APP_SECRET=
